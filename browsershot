def stack_offset(args: argparse.Namespace) -> tuple[int, int]:
    offset_x = -args.left if args.left is not None else args.right
    offset_y = -args.top if args.top is not None else args.bottom
    return 80 if offset_x is None else offset_x, 50 if offset_y is None else offset_y


def scale_stack_frames(frames: list[Image.Image], scale_down: float) -> list[Image.Image]:
    if scale_down == 0 or len(frames) == 1:
        return frames

    scaled_frames = []
    level_factor = 1 - scale_down
    for index, frame in enumerate(frames):
        factor = level_factor**index
        if factor == 1:
            scaled_frames.append(frame)
            continue
        size = (max(1, round(frame.width * factor)), max(1, round(frame.height * factor)))
        scaled_frames.append(frame.resize(size, Image.Resampling.LANCZOS))
    return scaled_frames


def stack_frames(
    frames: list[Image.Image],
    offset_x: int,
    offset_y: int,
    scale_down: float = 0.0,
) -> tuple[Image.Image, list[tuple[int, int]]]:
    if len(frames) == 1:
        return frames[0], [(0, 0)]

    level_factor = 1 - scale_down
    raw_positions = [(0, 0)]
    x = y = 0.0
    for index in range(1, len(frames)):
        step_scale = level_factor ** (index - 1)
        x += -offset_x * step_scale
        y += -offset_y * step_scale
        raw_positions.append((round(x), round(y)))
    min_x = min(x for x, _y in raw_positions)
    min_y = min(y for _x, y in raw_positions)
    positions = [(x - min_x, y - min_y) for x, y in raw_positions]
    width = max(x + frame.width for frame, (x, _y) in zip(frames, positions))
    height = max(y + frame.height for frame, (_x, y) in zip(frames, positions))
    out = Image.new("RGBA", (width, height), (0, 0, 0, 0))

    for frame, position in reversed(list(zip(frames, positions))):
        out.alpha_composite(frame, position)
    return out, positions


def default_output(source: Path, stacked: bool, iphone: bool, stylized: bool, light: bool) -> Path:
    parts = ["safari"]
    if stacked:
        parts.append("stack")
    if iphone:
        parts.append("iphone")
    parts.append("stylized" if stylized else "realistic")
    parts.append("light" if light else "dark")
    return source.with_name(source.name + "." + "-".join(parts) + ".png")


def main() -> int:
    args = parse_args()
    source_paths = [Path(sourcefile) for sourcefile in args.sourcefile]
    for source_path in source_paths:
        if not source_path.exists():
            print(f"browsershot: source file not found: {source_path}", file=sys.stderr)
            return 2

    frames = []
    source_transforms = []
    for source_path, mask_ops in zip(source_paths, args.source_mask_ops):
        try:
            source = Image.open(source_path).convert("RGBA")
        except Exception as exc:
            print(f"browsershot: could not open image {source_path}: {exc}", file=sys.stderr)
            return 2
        try:
            source = apply_mask_ops(source, mask_ops)
        except ValueError as exc:
            print(f"browsershot: invalid mask for {source_path}: {exc}", file=sys.stderr)
            return 2

        shadow = not args.no_shadow
        source_transforms.append(
            iphone_source_transform(source, args.stylized, shadow)
            if args.iphone
            else safari_source_transform(source, args.stylized, shadow)
        )
        frames.append(
            draw_iphone(source, args.address, args.light, args.stylized, shadow)
            if args.iphone
            else draw_safari(source, args.address, args.light, args.stylized, shadow)
        )

    frames = scale_stack_frames(frames, args.scale)
    framed, frame_positions = stack_frames(frames, *stack_offset(args), scale_down=args.scale)
    top_source_origin, top_source_scale = source_transforms[0]
    top_frame_position = frame_positions[0]
    top_source_origin = (top_source_origin[0] + top_frame_position[0], top_source_origin[1] + top_frame_position[1])
    try:
        framed, overlay_shift = apply_overlays(framed, args.overlay, top_source_origin, top_source_scale)
        top_source_origin = (top_source_origin[0] + overlay_shift[0], top_source_origin[1] + overlay_shift[1])
        framed = apply_cursors(framed, args.cursor, top_source_origin, top_source_scale)
    except ValueError as exc:
        print(f"browsershot: {exc}", file=sys.stderr)
        return 2
    output_path = (
        Path(args.output)
        if args.output
        else default_output(source_paths[0], len(source_paths) > 1, args.iphone, args.stylized, args.light)
    )
    output_path.parent.mkdir(parents=True, exist_ok=True)
    framed.save(output_path)
    print(output_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
